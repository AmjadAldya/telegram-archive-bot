# Telegram API credentials (from https://my.telegram.org)
API_ID=123456
API_HASH=your_api_hash

# Generate with: python -m scripts.generate_session
# This authenticates a real Telegram USER account (not a bot token), which is
# required to read history in private/protected groups the account is a
# member of. Keep it secret.
SESSION_STRING=your_session_string

# Optional but recommended: a real bot token (from @BotFather on Telegram)
# gives you a dedicated chat with a proper "/" command menu for /chats,
# /setsource, /setdest, /status, /pause, /resume, /resync - instead of
# typing them into your own Saved Messages, which clutters your notes.
# Only the account behind SESSION_STRING can use it, no matter who else
# messages the bot. Leave unset to keep using Saved Messages for commands.
# BOT_TOKEN=123456:your_bot_token

# Optional: source (protected group/channel) and destination chat. You do
# NOT need to set these - after starting the bot, send /chats (from the
# control bot above, or from Saved Messages if you didn't set BOT_TOKEN) to
# list your groups/channels, then /setsource and /setdest to pick them
# interactively. Your choice is saved in the database and used from then
# on. These env vars only matter as a one-time seed if the database has no
# configuration saved yet.
# SOURCE_CHAT_ID=-1001234567890
# DEST_CHAT_ID=@my_media_archive

# Anti-flood throttling: a random delay in this range is applied before every
# media transfer, and only one transfer runs at a time. Widen this if you see
# FloodWait warnings in the logs.
MIN_DELAY_SECONDS=3
MAX_DELAY_SECONDS=7
FLOOD_WAIT_MAX_RETRIES=5

# Comma-separated subset of: photo,video,document,audio,voice,video_note,animation
MEDIA_TYPES=photo,video,document,audio,voice,video_note,animation

# Scan the full existing source history once at startup (resumable, safe to
# re-run) in addition to mirroring new messages live.
SYNC_HISTORY_ON_START=true

DATABASE_URL=sqlite:///./data/telegram_mirror.db
LOG_LEVEL=INFO
DATA_DIR=data
